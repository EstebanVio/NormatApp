# DATABASE
DATABASE_URL="postgresql://user:password@localhost:5432/remitos_db"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRY="24h"
JWT_REFRESH_SECRET="your-refresh-secret-change-in-production"
JWT_REFRESH_EXPIRY="7d"

# SERVER
NODE_ENV="development"
PORT=3000
FRONTEND_URL="http://localhost:5173"
MOBILE_URL="exp://localhost:8081"

# STORAGE - S3
AWS_REGION="us-east-1"
AWS_S3_BUCKET="remitos-storage"
AWS_ACCESS_KEY_ID="your-access-key"
AWS_SECRET_ACCESS_KEY="your-secret-key"
AWS_S3_ENDPOINT="" # Leave empty for AWS, or set custom endpoint for minio/s3 compatible
STORAGE_TYPE="local" # "local" or "s3"
UPLOAD_DIR="./uploads"

# REDIS (for WebSockets and caching)
REDIS_URL="redis://localhost:6379"

# FILE UPLOAD
MAX_FILE_SIZE=10485760 # 10MB in bytes
ALLOWED_MIME_TYPES="application/pdf,image/jpeg,image/png"

# LOGGING
LOG_LEVEL="info"

# SECURITY
RATE_LIMIT_WINDOW_MS=900000 # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100
CORS_ORIGIN="http://localhost:5173,http://localhost:8081"

# TIMEZONE
TZ="America/Argentina/Cordoba"
